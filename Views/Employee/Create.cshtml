@model EmployeeMVC.Models.Employee

<h2>Add Employee</h2>

<form asp-action="Create" method="post">

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="EMP_NAME" class="form-label"></label>
        <input asp-for="EMP_NAME" class="form-control" />
        <span asp-validation-for="EMP_NAME" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EMP_MOBILE" class="form-label"></label>
        <input asp-for="EMP_MOBILE" class="form-control" />
        <span asp-validation-for="EMP_MOBILE" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EMP_EMAIL" class="form-label"></label>
        <input asp-for="EMP_EMAIL" class="form-control" />
        <span asp-validation-for="EMP_EMAIL" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Department</label>

        <select asp-for="EMP_DEPARTMENT_ID"
                asp-items="ViewBag.Departments"
                class="form-select">
            <option value="">-- Select Department --</option>
        </select>

        <span asp-validation-for="EMP_DEPARTMENT_ID" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Designation</label>

        <select asp-for="EMP_DESIGNATION_ID"
                asp-items="ViewBag.Designations"
                class="form-select">
            <option value="">-- Select Designation --</option>
        </select>

        <span asp-validation-for="EMP_DESIGNATION_ID" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">
        Save Employee
    </button>

    <a asp-controller="Home"
       asp-action="Index"
       class="btn btn-secondary">
        Back
    </a>

</form>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}